# Environment Variables Template
# Copy this file to .env.local and update values

# API Configuration
VITE_API_URL=http://localhost:5000/api
VITE_API_TIMEOUT=30000

# Application Configuration
VITE_APP_NAME=Dearest Mide
VITE_APP_URL=http://localhost:8000
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_COMMENTS=true
VITE_ENABLE_SHARING=true
VITE_ENABLE_NEWSLETTER=true
VITE_ENABLE_DARK_MODE=true

# Analytics (Optional)
VITE_GA_ID=
VITE_ANALYTICS_ENABLED=false

# Social Media
VITE_TWITTER_URL=https://twitter.com/dearest-mide
VITE_FACEBOOK_URL=https://facebook.com/dearest-mide
VITE_INSTAGRAM_URL=https://instagram.com/dearest-mide
VITE_LINKEDIN_URL=https://linkedin.com/company/dearest-mide
